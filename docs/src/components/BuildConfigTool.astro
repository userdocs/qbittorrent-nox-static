<script>
	declare global {
		interface Window {
			Prism: { highlightAll(): void; highlightElement(el: Element): void };
		}
	}

	(function () {
		const container = document.getElementById(
			"buildConfig",
		) as HTMLDivElement | null;
		const viewToggle = document.getElementById(
			"configViewToggle",
		) as HTMLInputElement | null;
		const resetButton = document.getElementById(
			"resetButton",
		) as HTMLButtonElement | null;
		const selects = document.querySelectorAll(
			"select[data-variable]",
		) as NodeListOf<HTMLSelectElement>;

		// Saved per-context settings for port and volume (Docker vs Dockerfile tabs)
		const savedSettings = {
			docker: { port: "", customPort: "", volume: "", customVolume: "" },
			dockerfile: { port: "", customPort: "", volume: "", customVolume: "" },
		};

		// ─── Helpers ──────────────────────────────────────────────────────────────

		function isDockerfileActive(): boolean {
			return container?.dataset.dockerfileTab === "true";
		}

		function isLegacyMode(): boolean {
			return (
				(
					document.getElementById(
						"config_qbt_legacy_mode",
					) as HTMLSelectElement | null
				)?.value === "yes"
			);
		}

		function getScriptCmd(isLocal = false): string {
			const sub = isLegacyMode() ? "all" : "bootstrap_deps all";
			return isLocal
				? `./qbt.bash ${sub}`
				: `bash <(curl -sL usrdx.github.io/s/qbt.bash) ${sub}`;
		}

		function getSelectValue(select: HTMLSelectElement): string {
			if (select.value !== "custom") return select.value;
			const custom = document.getElementById(
				`custom_input_${select.dataset.variable}`,
			) as HTMLInputElement | null;
			return custom?.value.trim() ?? "";
		}

		function collectEnvVars(excludeDockerVars = true): string[] {
			const dockerKeys = new Set([
				"qbt_docker_base",
				"qbt_docker_port",
				"qbt_docker_volume",
				"qbt_docker_user",
			]);
			const vars: string[] = [];
			selects.forEach((s) => {
				const v = s.dataset.variable;
				const def = s.dataset.default;
				if (!v || def === undefined) return;
				if (excludeDockerVars && dockerKeys.has(v)) return;
				const cur = getSelectValue(s);
				if (cur !== def && cur !== "" && cur !== "default")
					vars.push(`${v}="${cur}"`);
			});
			return vars;
		}

		function formatEnvVars(vars: string[], indent = ""): string {
			return vars.map((v) => `${indent}${v} \\`).join("\n");
		}

		function highlight(): void {
			setTimeout(() => window.Prism?.highlightAll(), 50);
		}

		// ─── Docker config extraction ─────────────────────────────────────────────

		type DockerConfig = {
			baseImage: string;
			packageManager: string;
			shell: string;
			portMapping: string;
			volumeMapping: string;
			dockerUser: string;
			envVars: string[];
		};

		function getDockerConfig(): DockerConfig {
			let baseImage = "alpine:latest";
			let packageManager = "apk update && apk add bash git curl";
			let shell = "/bin/ash";
			let portMapping = "8080:8080";
			let volumeMapping = "~/qbt:/root";
			let dockerUser = "root";
			const envVars: string[] = [];

			selects.forEach((s) => {
				const v = s.dataset.variable;
				const def = s.dataset.default ?? "";
				const cur = getSelectValue(s);

				switch (v) {
					case "qbt_docker_base":
						baseImage = cur || def;
						if (baseImage.includes("ubuntu") || baseImage.includes("debian")) {
							packageManager =
								"apt-get update && \\\n\tapt-get install -y git curl";
							shell = "/bin/bash";
						}
						break;
					case "qbt_docker_port":
						portMapping = cur || def || "8080:8080";
						break;
					case "qbt_docker_volume":
						volumeMapping = cur || def || "~/qbt:/root";
						break;
					case "qbt_docker_user":
						dockerUser = cur || def || "root";
						break;
					default:
						if (cur !== def && cur !== "") envVars.push(`${v}="${cur}"`);
				}
			});

			if (dockerUser === "username") {
				packageManager = packageManager.replace("git curl", "git curl sudo");
				if (volumeMapping.includes(":/root")) {
					volumeMapping = volumeMapping.replace(":/root", ":/home/username");
				}
			}

			return {
				baseImage,
				packageManager,
				shell,
				portMapping,
				volumeMapping,
				dockerUser,
				envVars,
			};
		}

		function getUserSetupCmds(baseImage: string, dockerUser: string): string[] {
			if (dockerUser !== "username") return [];
			if (baseImage.includes("ubuntu")) {
				return [
					"usermod -l username -d /home/username ubuntu",
					"groupmod -n username ubuntu",
					'printf "%s" "username ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/username',
					"chmod 0440 /etc/sudoers.d/username",
				];
			}
			if (baseImage.includes("alpine")) {
				return [
					"adduser -h /home/username -Ds /bin/bash -u 1000 username",
					'printf "%s" "username ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/username',
				];
			}
			return [
				"useradd -ms /bin/bash -u 1000 username",
				'printf "%s" "username ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/username',
				"chmod 0440 /etc/sudoers.d/username",
			];
		}

		function getUserSetup(baseImage: string, dockerUser: string): string {
			const cmds = getUserSetupCmds(baseImage, dockerUser);
			return cmds.length ? ` && \\\n    ${cmds.join(" && \\\n    ")}` : "";
		}

		// ─── Command generators ───────────────────────────────────────────────────

		function generateNativeCommand(): string {
			const vars = collectEnvVars(true);
			const cmd = getScriptCmd();
			return vars.length ? `${formatEnvVars(vars)}\n${cmd}` : cmd;
		}

		function generateLocalCommand(): string {
			const vars = collectEnvVars(true);
			const download = `curl -sL usrdx.github.io/s/qbt.bash -o qbt.bash && \\\nchmod +x qbt.bash`;
			const cmd = getScriptCmd(true);
			return vars.length
				? `${download}\n${formatEnvVars(vars)}\n${cmd}`
				: `${download}\n${cmd}`;
		}

		function generateDockerCommand(isLocal: boolean): string {
			const {
				baseImage,
				packageManager,
				shell,
				portMapping,
				volumeMapping,
				dockerUser,
				envVars,
			} = getDockerConfig();
			const userSetup = getUserSetup(baseImage, dockerUser);
			const workDir = dockerUser === "username" ? "/home/username" : "/root";
			const localDir = volumeMapping.split(":")[0];

			let scriptPath: string;
			let scriptCmd: string;
			const isUser = dockerUser === "username";

			if (isLocal) {
				scriptPath = `${workDir}/qbt.bash`;
				const baseCmd = isLegacyMode()
					? `bash ${scriptPath} all`
					: `bash ${scriptPath} bootstrap_deps all`;
				scriptCmd = isUser ? `sudo -E -H -u username ${baseCmd}` : baseCmd;
			} else {
				const baseCmd = getScriptCmd();
				scriptCmd = isUser
					? `sudo -E -H -u username bash -c "${baseCmd}"`
					: baseCmd;
			}

			const downloadLine = isLocal
				? `mkdir -p ${localDir} && chmod 755 ${localDir} && \\\ncurl -sL usrdx.github.io/s/qbt.bash -o ${localDir}/qbt.bash && \\\n`
				: "";

			const volumeLines = `\t-v ${volumeMapping} \\`;

			const envBlock = envVars.length
				? envVars.map((v) => `\t-e ${v} \\\n`).join("")
				: "";

			const debianEnvLines = "";

			return (
				`${downloadLine}docker run -it -w ${workDir} \\\n` +
				`\t-p ${portMapping} \\\n` +
				`${volumeLines}\n` +
				`${debianEnvLines}` +
				`${envBlock}` +
				`\t${baseImage} ${shell} -c \\\n` +
				`\t'${packageManager}${userSetup} && \\\n` +
				`\t${scriptCmd}'`
			);
		}

		function generateDockerfile(): string {
			const { baseImage, dockerUser, envVars } = getDockerConfig();

			let dockerfilePkgMgr = "apk update && apk add bash git curl";
			if (baseImage.includes("ubuntu") || baseImage.includes("debian")) {
				dockerfilePkgMgr =
					"apt-get update && \\\n    apt-get install -y git curl";
			}
			if (dockerUser === "username") {
				dockerfilePkgMgr = dockerfilePkgMgr.replace(
					"git curl",
					"git curl sudo",
				);
			}

			const portSelect = document.getElementById(
				"config_qbt_docker_port",
			) as HTMLSelectElement | null;
			const rawPort = portSelect ? getSelectValue(portSelect) : "8080";
			const exposedPort = rawPort.includes(":")
				? rawPort.split(":")[1]
				: rawPort || "8080";

			const workDir = dockerUser === "username" ? "/home/username" : "/root";

			const debianEnvBlock = "";

			const setupCmds = getUserSetupCmds(baseImage, dockerUser);
			const userSetupBlock = setupCmds.length
				? `\n\n# Set up username user\nRUN ${setupCmds.join(" && \\\n    ")}`
				: "";

			const envSection = envVars.length
				? `\n\n# Environment variables\nENV ${envVars.map((e, i) => (i < envVars.length - 1 ? `${e} \\` : e)).join("\n    ")}`
				: "";

			const userSection = dockerUser === "username" ? "\n\nUSER username" : "";
			const cmdArgs = isLegacyMode() ? `"all"` : `"bootstrap_deps", "all"`;

			return (
				`FROM ${baseImage}\n\n` +
				`${debianEnvBlock}` +
				`# Install dependencies\nRUN ${dockerfilePkgMgr}${userSetupBlock}\n\n` +
				`# Download build script\nRUN curl -sL usrdx.github.io/s/qbt.bash -o /usr/local/bin/qbt.bash && \\\n    chmod +x /usr/local/bin/qbt.bash\n\n` +
				`WORKDIR ${workDir}\n\n` +
				`EXPOSE ${exposedPort}` +
				`${envSection}` +
				`${userSection}\n\n` +
				`# Run build\nCMD ["qbt.bash", ${cmdArgs}]`
			);
		}

		// ─── UI updates ───────────────────────────────────────────────────────────

		function updateCommands(): void {
			const outputs: Record<string, string> = {
				native: generateNativeCommand(),
				local: generateLocalCommand(),
				docker: generateDockerCommand(false),
				"docker-local": generateDockerCommand(true),
				dockerfile: generateDockerfile(),
			};
			Object.entries(outputs).forEach(([key, text]) => {
				const el = document.getElementById(`output-${key}`);
				if (el) el.textContent = text;
			});
			highlight();
		}

		function updateLEDs(): void {
			selects.forEach((select) => {
				const variable = select.dataset.variable;
				const def = select.dataset.default;
				if (!variable || def === undefined) return;

				const led = document.querySelector(
					`.status-led[data-variable="${variable}"]`,
				) as HTMLElement | null;
				const label = document.querySelector(
					`.status-label[data-variable="${variable}"]`,
				) as HTMLElement | null;

				let isDefault: boolean;
				if (select.value === "custom") {
					const custom = document.getElementById(
						`custom_input_${variable}`,
					) as HTMLInputElement | null;
					const val = custom?.value.trim() ?? "";
					isDefault = val === "" || val === def;
				} else {
					isDefault = select.value === def;
				}

				led?.classList.toggle("modified", !isDefault);
				if (label) label.textContent = isDefault ? "Default" : "Modified";
			});
		}

		function handleCustomInput(select: HTMLSelectElement): void {
			const variable = select.dataset.variable;
			const customInput = document.getElementById(
				`custom_input_${variable}`,
			) as HTMLInputElement | null;
			const descP = document.getElementById(
				`description_${variable}`,
			) as HTMLParagraphElement | null;
			if (!customInput) return;

			const isCustom = select.value === "custom";
			customInput.style.display = isCustom ? "block" : "none";
			if (descP) descP.style.display = isCustom ? "none" : "block";

			if (isCustom) {
				if (!customInput.value.trim()) {
					customInput.value = select.dataset.default ?? "";
				}
				customInput.focus();
				customInput.select();
			} else {
				customInput.value = "";
			}
		}

		// ─── Port options (Docker vs Dockerfile context) ───────────────────────────

		function updatePortOptions(forDockerfile: boolean): void {
			const portSelect = document.getElementById(
				"config_qbt_docker_port",
			) as HTMLSelectElement | null;
			const customInput = document.getElementById(
				"custom_input_qbt_docker_port",
			) as HTMLInputElement | null;
			const labelEl = portSelect
				?.closest(".config-option")
				?.querySelector("h4") as HTMLElement | null;
			if (!portSelect) return;

			// Snapshot current context before switching
			const curCtx = isDockerfileActive()
				? savedSettings.dockerfile
				: savedSettings.docker;
			curCtx.port = portSelect.value;
			curCtx.customPort = customInput?.value ?? "";

			if (!portSelect.dataset.originalOptions) {
				portSelect.dataset.originalOptions = portSelect.innerHTML;
				portSelect.dataset.originalDefault = portSelect.dataset.default ?? "";
			}

			if (forDockerfile) {
				portSelect.innerHTML = `
					<option value="8080">8080 (Default)</option>
					<option value="8081">8081</option>
					<option value="9090">9090</option>
					<option value="custom">Custom...</option>
				`;
				portSelect.dataset.default = "8080";
				if (customInput)
					customInput.placeholder = "Enter container port (e.g., 3000)";
				if (labelEl) {
					labelEl.dataset.originalText =
						labelEl.dataset.originalText || labelEl.textContent || "";
					labelEl.textContent = "Container Port";
				}

				const saved = savedSettings.dockerfile;
				if (
					saved.port &&
					portSelect.querySelector(`option[value="${saved.port}"]`)
				) {
					portSelect.value = saved.port;
				} else {
					const cur = savedSettings.docker.port;
					const containerPort = cur.includes(":") ? cur.split(":")[1] : cur;
					portSelect.value = portSelect.querySelector(
						`option[value="${containerPort}"]`,
					)
						? containerPort
						: "8080";
				}
			} else {
				portSelect.innerHTML = portSelect.dataset.originalOptions!;
				portSelect.dataset.default =
					portSelect.dataset.originalDefault ?? portSelect.dataset.default;
				if (customInput) customInput.placeholder = "Enter custom port mapping";
				if (labelEl?.dataset.originalText)
					labelEl.textContent = labelEl.dataset.originalText;

				const saved = savedSettings.docker;
				if (
					saved.port &&
					portSelect.querySelector(`option[value="${saved.port}"]`)
				) {
					portSelect.value = saved.port;
				} else {
					portSelect.value = portSelect.options[0]?.value ?? "";
				}
			}

			portSelect.dispatchEvent(new Event("change", { bubbles: true }));
		}

		// ─── Tab visibility ───────────────────────────────────────────────────────

		const PAGE_TAB_NAMES = new Set([
			"notes",
			"alpine",
			"debian",
			"ubuntu",
			"build helper",
		]);

		function applyTabState(tabText: string): void {
			if (!container) return;
			const isDocker =
				tabText.includes("docker") || tabText.includes("dockerfile");
			const isDockerfile = tabText.includes("dockerfile");

			// Save volume settings for the outgoing context
			const volumeSelect = document.getElementById(
				"config_qbt_docker_volume",
			) as HTMLSelectElement | null;
			const volumeCustom = document.getElementById(
				"custom_input_qbt_docker_volume",
			) as HTMLInputElement | null;
			const outCtx = isDockerfileActive()
				? savedSettings.dockerfile
				: savedSettings.docker;
			if (volumeSelect) {
				outCtx.volume = volumeSelect.value;
				outCtx.customVolume = volumeCustom?.value ?? "";
			}

			container.dataset.dockerTab = isDocker ? "true" : "false";
			container.dataset.dockerfileTab = isDockerfile ? "true" : "false";

			updatePortOptions(isDockerfile);

			// Restore volume settings for the incoming context
			const inCtx = isDockerfile
				? savedSettings.dockerfile
				: savedSettings.docker;
			if (
				volumeSelect &&
				inCtx.volume &&
				volumeSelect.querySelector(`option[value="${inCtx.volume}"]`)
			) {
				volumeSelect.value = inCtx.volume;
				if (inCtx.volume === "custom" && volumeCustom)
					volumeCustom.value = inCtx.customVolume;
			}
		}

		function resolveActiveTabText(): string {
			for (const tab of document.querySelectorAll<HTMLElement>(
				'[role="tab"][aria-selected="true"]',
			)) {
				const text = (tab.textContent ?? "").trim().toLowerCase();
				if (!PAGE_TAB_NAMES.has(text)) return text;
			}
			const panel = document.querySelector<HTMLElement>(
				'[role="tabpanel"]:not([hidden])',
			);
			if (panel) {
				const tabId = panel.getAttribute("aria-labelledby");
				const tab = tabId ? document.getElementById(tabId) : null;
				const text = (tab?.textContent ?? "").trim().toLowerCase();
				if (tab && !PAGE_TAB_NAMES.has(text)) return text;
			}
			return "";
		}

		function onTabClick(e: Event): void {
			const text = ((e.currentTarget as HTMLElement).textContent ?? "")
				.trim()
				.toLowerCase();
			applyTabState(text);
			updateCommands();
		}

		function attachTabListeners(): void {
			document.querySelectorAll<HTMLElement>('[role="tab"]').forEach((tab) => {
				tab.removeEventListener("click", onTabClick);
				tab.addEventListener("click", onTabClick);
			});
		}

		// ─── Dependencies ──────────────────────────────────────────────────────────

		function applyBoostCap(isLt12: boolean): void {
			const boostSel = document.querySelector<HTMLSelectElement>(
				'select[data-variable="qbt_boost_tag"]',
			);
			const boostDesc = document.getElementById(
				"description_qbt_boost_tag",
			) as HTMLParagraphElement | null;
			if (!boostSel) return;

			if (isLt12) {
				boostSel.value = "boost-1.86.0";
				handleCustomInput(boostSel);
				if (boostDesc) {
					if (!boostDesc.dataset.originalText)
						boostDesc.dataset.originalText = boostDesc.textContent ?? "";
					boostDesc.textContent =
						"Capped at boost-1.86.0 — maximum supported version for libtorrent 1.2.";
				}
			} else {
				boostSel.value = boostSel.dataset.default ?? "";
				handleCustomInput(boostSel);
				if (boostDesc?.dataset.originalText) {
					boostDesc.textContent = boostDesc.dataset.originalText;
					delete boostDesc.dataset.originalText;
				}
			}
		}

		function handleDependencies(changed: HTMLSelectElement): void {
			const v = changed.dataset.variable;
			const cur = getSelectValue(changed);

			if (v === "qbt_libtorrent_version") {
				const tag = document.querySelector<HTMLSelectElement>(
					'select[data-variable="qbt_libtorrent_tag"]',
				);
				if (tag)
					tag.value =
						cur === "1.2"
							? (tag.options[1]?.value ?? "v1.2.20")
							: (tag.options[0]?.value ?? "v2.0.11");
				applyBoostCap(cur === "1.2");
			}

			if (v === "qbt_libtorrent_tag") {
				const ver = document.querySelector<HTMLSelectElement>(
					'select[data-variable="qbt_libtorrent_version"]',
				);
				const isLt12 = cur.startsWith("v1.2");
				if (ver) ver.value = isLt12 ? "1.2" : "2.0";
				applyBoostCap(isLt12);
			}

			if (v === "qbt_qt_version") {
				const tag = document.querySelector<HTMLSelectElement>(
					'select[data-variable="qbt_qt_tag"]',
				);
				if (tag)
					tag.value =
						cur === "5"
							? (tag.options[1]?.value ?? "v5.15.17")
							: (tag.options[0]?.value ?? "v6.9.1");
			}

			if (v === "qbt_qt_tag") {
				const ver = document.querySelector<HTMLSelectElement>(
					'select[data-variable="qbt_qt_version"]',
				);
				if (ver) ver.value = cur.startsWith("v5.") ? "5" : "6";
			}

			if (v === "qbt_docker_user") {
				const volSel = document.querySelector<HTMLSelectElement>(
					'select[data-variable="qbt_docker_volume"]',
				);
				if (volSel) {
					const isUser = cur === "username";
					const fromDir = isUser ? ":/root" : ":/home/username";
					const toDir = isUser ? ":/home/username" : ":/root";

					// Update each option value and label
					Array.from(volSel.options).forEach((opt) => {
						if (opt.value === "custom") return;
						opt.value = opt.value.replace(fromDir, toDir);
						opt.label = opt.value;
						opt.textContent = opt.value;
					});

					// Update custom input placeholder path hint
					const customInput = document.getElementById(
						"custom_input_qbt_docker_volume",
					) as HTMLInputElement | null;
					if (customInput?.value) {
						customInput.value = customInput.value.replace(fromDir, toDir);
					}
				}
			}

			if (v === "qbt_cross_name") {
				const staticSel = document.querySelector<HTMLSelectElement>(
					'[data-variable="qbt_static_ish"]',
				);
				if (staticSel) {
					const cross = cur !== "";
					staticSel.disabled = cross;
					staticSel.style.opacity = cross ? "0.6" : "1";
					staticSel.style.cursor = cross ? "not-allowed" : "pointer";
					if (cross) staticSel.value = "no";
				}
			}
		}

		// ─── Event wiring ─────────────────────────────────────────────────────────

		selects.forEach((select) => {
			select.addEventListener("change", (e) => {
				const target = e.target as HTMLSelectElement;
				handleCustomInput(target);
				handleDependencies(target);
				updateCommands();
				updateLEDs();
			});
		});

		setTimeout(() => {
			document
				.querySelectorAll<HTMLInputElement>('[id^="custom_input_"]')
				.forEach((input) => {
					input.addEventListener("input", () => {
						updateCommands();
						updateLEDs();
					});
				});
		}, 100);

		// View toggle
		const savedView = localStorage.getItem("buildconfig-view") ?? "basic";
		if (container) container.dataset.view = savedView;
		if (viewToggle) {
			viewToggle.checked = savedView === "advanced";
			viewToggle.addEventListener("change", () => {
				const view = viewToggle.checked ? "advanced" : "basic";
				if (container) container.dataset.view = view;
				localStorage.setItem("buildconfig-view", view);
			});
		}

		// Reset
		resetButton?.addEventListener("click", () => {
			if (container) container.dataset.view = "basic";
			if (viewToggle) {
				viewToggle.checked = false;
				localStorage.setItem("buildconfig-view", "basic");
			}

			savedSettings.docker = {
				port: "",
				customPort: "",
				volume: "",
				customVolume: "",
			};
			savedSettings.dockerfile = {
				port: "",
				customPort: "",
				volume: "",
				customVolume: "",
			};

			selects.forEach((select) => {
				const def = select.dataset.default ?? "";

				// Revert volume options back to :/root paths if they were changed
				if (select.dataset.variable === "qbt_docker_volume") {
					Array.from(select.options).forEach((opt) => {
						if (opt.value === "custom") return;
						opt.value = opt.value.replace(":/home/username", ":/root");
						opt.label = opt.value;
						opt.textContent = opt.value;
					});
				}

				select.value = def;
				select.disabled = false;
				select.style.opacity = "1";
				select.style.cursor = "pointer";
				const customInput = document.getElementById(
					`custom_input_${select.dataset.variable}`,
				) as HTMLInputElement | null;
				const descP = document.getElementById(
					`description_${select.dataset.variable}`,
				) as HTMLParagraphElement | null;
				if (customInput) {
					customInput.style.display = "none";
					customInput.value = "";
				}
				if (descP) descP.style.display = "block";
			});

			updateCommands();
			updateLEDs();
		});

		// Copy buttons
		document
			.querySelectorAll<HTMLButtonElement>(".copy-button[data-output]")
			.forEach((btn) => {
				btn.addEventListener("click", async () => {
					const text =
						document.getElementById(`output-${btn.dataset.output}`)
							?.textContent ?? "";
					try {
						await navigator.clipboard.writeText(text);
						btn.textContent = "Copied!";
					} catch {
						btn.textContent = "Failed";
					}
					setTimeout(() => {
						btn.textContent = "Copy";
					}, 2000);
				});
			});

		// ─── Initialization ───────────────────────────────────────────────────────

		function init(): void {
			if (!document.getElementById("config_qbt_legacy_mode")) {
				setTimeout(init, 100);
				return;
			}

			const initialText = resolveActiveTabText();
			if (container) {
				container.dataset.dockerTab =
					initialText.includes("docker") || initialText.includes("dockerfile")
						? "true"
						: "false";
				container.dataset.dockerfileTab = initialText.includes("dockerfile")
					? "true"
					: "false";
				updatePortOptions(initialText.includes("dockerfile"));
			}

			attachTabListeners();

			const tabsContainer = document.querySelector(".starlight-tabs");
			if (tabsContainer) {
				new MutationObserver(() => setTimeout(attachTabListeners, 50)).observe(
					tabsContainer,
					{ childList: true, subtree: true },
				);
			}

			updateLEDs();

			(function tryHighlight(): void {
				if (typeof window.Prism !== "undefined") {
					updateCommands();
				} else {
					setTimeout(tryHighlight, 100);
				}
			})();
		}

		setTimeout(init, 200);
	})();
</script>
