<!-- Prism.js theme loader - theme-aware -->
<script is:inline>
	(function () {
		let prismLink = null;

		function loadPrismTheme(isLight) {
			if (prismLink) prismLink.remove();
			prismLink = document.createElement("link");
			prismLink.rel = "stylesheet";
			prismLink.href = isLight
				? "https://cdnjs.cloudflare.com/ajax/libs/prism/1.30.0/themes/prism.min.css"
				: "https://cdnjs.cloudflare.com/ajax/libs/prism/1.30.0/themes/prism-dark.min.css";
			document.head.appendChild(prismLink);
		}

		loadPrismTheme(
			document.documentElement.getAttribute("data-theme") === "light",
		);

		new MutationObserver(() => {
			const isLight =
				document.documentElement.getAttribute("data-theme") === "light";
			loadPrismTheme(isLight);
			setTimeout(() => window.Prism?.highlightAll(), 100);
		}).observe(document.documentElement, {
			attributes: true,
			attributeFilter: ["data-theme"],
		});
	})();
</script>

