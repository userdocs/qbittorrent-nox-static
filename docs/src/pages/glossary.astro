---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

interface GlossaryItem {
	fileBase: string;
	title: string;
}

const basePath = `/${Astro.url.pathname.split("/")[1]}`;

// Get all glossary markdown files
const posts = import.meta.glob<{ frontmatter: { title: string } }>(
	"/src/content/docs/glossary/*.md",
	{ eager: true },
);

// Extract fileBase and title, then sort alphabetically by title
const items: GlossaryItem[] = Object.entries(posts)
	.map(([path, post]) => ({
		fileBase:
			path
				.split("/")
				.pop()
				?.replace(/\.mdx?$/, "") ?? "",
		title: post.frontmatter.title,
	}))
	.sort((a, b) => a.title.localeCompare(b.title));

// Group sorted items by first letter
const sections = Map.groupBy(items, (item) =>
	item.title.charAt(0).toUpperCase(),
);

// Generate headings for the TOC from the sorted section keys
const headings = [...sections.keys()].map((letter) => ({
	depth: 2 as const,
	slug: letter,
	text: letter,
}));
---

<StarlightPage frontmatter={{ title: "Glossary" }} headings={headings}>
	{
		[...sections.entries()].map(([letter, files]) => (
			<>
				<h2 id={letter}>{letter}</h2>
				<ul>
					{files.map(({ fileBase, title }) => (
						<li>
							<a href={`${basePath}/glossary/${fileBase}`}>{title}</a>
						</li>
					))}
				</ul>
			</>
		))
	}
</StarlightPage>
